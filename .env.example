# VWorld Open API (https://www.vworld.kr/dev/v4dv_apiKey2_s001.do)
VWORLD_API_KEY=your_api_key_here
# VWorld 인증키에 등록한 서비스 URL과 동일해야 함
VWORLD_DOMAIN=http://www.rabbit-archi2025.com

# Korean Law MCP / 법제처 Open API (https://open.law.go.kr/LSO/openApi/guideList.do)
LAW_OC=your_law_oc_here
# 법제처 HTTPS 연결이 차단/리셋되는 환경에서는 http로 설정합니다.
# LAW_API_PROTOCOL=http
# 법제처 API가 Referer/User-Agent를 요구하는 경우 기본값을 사용하거나 필요 시 덮어씁니다.
# LAW_REFERER=https://www.law.go.kr/
# LAW_USER_AGENT=Mozilla/5.0

# 토지이음/토지이용규제정보서비스 (공공데이터포털)
EUM_SERVICE_KEY=your_data_go_kr_service_key_here
# 필요 시 공공데이터포털 상세 명세의 URL로 덮어쓸 수 있습니다.
# EUM_LAND_USE_RESTRICTION_URL=http://apis.data.go.kr/1613000/LuplStat/getLuplStatList

# 지구단위계획 결정도서/시행지침 OCR
# 로컬 Tesseract가 설치된 경우 이미지(JPG/PNG/WEBP) OCR을 시도합니다.
# 스캔 PDF는 Poppler의 pdftoppm으로 페이지 이미지를 만든 후 OCR합니다.
# FAM_OCR_PROVIDER=local-tesseract
# TESSERACT_CMD=tesseract
# PDF_TO_IMAGE_CMD=pdftoppm
# FAM_OCR_LANG=kor+eng
# FAM_OCR_TIMEOUT_MS=30000
# FAM_OCR_PDF_DPI=200
# FAM_OCR_PDF_MAX_PAGES=5
# FAM_OCR_PDF_CONVERT_TIMEOUT_MS=30000

# true이면 모든 지번에 동일한 가짜 데이터가 나옵니다 (테스트용만 사용)
# FAM_DEMO_MODE=false
